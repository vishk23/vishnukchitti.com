---
// Static hypnogram: one night's sleep-stage segments as horizontal bands over
// time. Each stage occupies its own row (awake highest, deep lowest) and each
// segment is a rect spanning its wall-clock duration. Built at build time as
// inline SVG — no client JS. Neutral by construction: stages are distinguished
// by row position plus currentColor opacity, so the design pass owns the palette.
import { loadHypnogram } from '../lib/sensor';

interface Props {
  dataKey?: string;
  caption?: string;
}

const { dataKey = 'hypnogram', caption } = Astro.props;

const hypno = loadHypnogram(dataKey);

// Row order top→bottom and a neutral opacity ramp (depth of sleep).
const STAGE_ROWS = ['awake', 'rem', 'light', 'deep'];
const STAGE_OPACITY: Record<string, number> = {
  awake: 0.25,
  rem: 0.45,
  light: 0.65,
  deep: 0.9,
};

const W = 600;
const H = 160;
const PAD = 8;
const rowH = (H - 2 * PAD) / STAGE_ROWS.length;

interface Band {
  x: number;
  y: number;
  w: number;
  h: number;
  stage: string;
  opacity: number;
}

let bands: Band[] = [];
if (hypno && hypno.segments.length > 0) {
  const t0 = hypno.segments[0].startUnix;
  const t1 = hypno.segments[hypno.segments.length - 1].endUnix;
  const span = t1 - t0 || 1;
  bands = hypno.segments.map((seg) => {
    const rowIdx = Math.max(0, STAGE_ROWS.indexOf(seg.stage));
    const x = PAD + ((seg.startUnix - t0) / span) * (W - 2 * PAD);
    const w = Math.max(0.5, ((seg.endUnix - seg.startUnix) / span) * (W - 2 * PAD));
    return {
      x,
      y: PAD + rowIdx * rowH,
      w,
      h: rowH,
      stage: seg.stage,
      opacity: STAGE_OPACITY[seg.stage] ?? 0.5,
    };
  });
}
---

<figure class="figure hypnogram" data-hypnogram>
  {
    hypno ? (
      <svg
        class="hypnogram-svg"
        width="100%"
        height="180"
        viewBox={`0 0 ${W} ${H}`}
        preserveAspectRatio="none"
        role="img"
        aria-label="One night of sleep stages: awake, REM, light, deep"
      >
        {bands.map((b) => (
          <rect
            class={`stage stage-${b.stage}`}
            data-stage={b.stage}
            x={b.x.toFixed(1)}
            y={b.y.toFixed(1)}
            width={b.w.toFixed(1)}
            height={b.h.toFixed(1)}
            fill="currentColor"
            fill-opacity={b.opacity}
          />
        ))}
      </svg>
    ) : (
      <p class="figure-empty">Hypnogram data unavailable.</p>
    )
  }
  <ul class="hypnogram-legend" aria-hidden="true">
    {STAGE_ROWS.map((s) => <li data-stage={s}>{s}</li>)}
  </ul>
  <figcaption>
    {caption ??
      "One night's sleep stages from my own WHOOP data."}
  </figcaption>
</figure>

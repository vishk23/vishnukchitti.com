---
import Layout from '../layouts/Layout.astro';
import WaveformScrub from '../components/WaveformScrub.astro';
import ChannelToggle from '../components/ChannelToggle.astro';
import ProjectSignal from '../components/ProjectSignal.astro';
import { getCollection, render } from 'astro:content';

// All homepage copy comes from the `sections` collection, ordered by `order`.
const sections = (await getCollection('sections')).sort(
  (a, b) => a.data.order - b.data.order,
);

// Section -> anchor id so the nav (/#work etc.) can target it.
const anchorFor: Record<string, string> = {
  hero: 'top',
  'selected-work': 'work',
  experience: 'experience',
  contact: 'contact',
};

// Pre-render each section body (markdown) to a component.
const rendered = await Promise.all(
  sections.map(async (entry) => ({
    entry,
    Body: (await render(entry)).Content,
  })),
);
---

<Layout>
  {
    rendered.map(({ entry, Body }) => (
      <section id={anchorFor[entry.data.section] ?? entry.data.section} data-reveal>
        {entry.data.section === 'hero' && <p class="hero-eyebrow">Boston, MA · data engineer</p>}
        {entry.data.section === 'hero' ? <h1>{entry.data.heading}</h1> : <h2>{entry.data.heading}</h2>}
        {entry.data.lede && <p class="muted">{entry.data.lede}</p>}

        {/* Proof island lives inside the hero section flow. */}
        {entry.data.section === 'hero' && (
          <WaveformScrub
            dataKey="ppg-continuous"
            caption="My own heartbeat, decoded from the WHOOP strap's raw green-optical channel — 45 seconds at 25 Hz, a signal the vendor never exposes."
          />
        )}

        {entry.data.section === 'hero' && entry.data.note && (
          <p class="voice-note"><span>voice system</span>{entry.data.note}</p>
        )}

        {entry.data.items && (
          <ul>
            {entry.data.items.map((item) => (
              <li data-reveal>
                <div class="item-copy">
                  <strong>
                    {item.href ? <a href={item.href}>{item.title}</a> : item.title}
                  </strong>
                  {item.meta && <span class="muted"> — {item.meta}</span>}
                  {item.body && <p>{item.body}</p>}
                </div>
                {entry.data.section === 'selected-work' && item.href && (
                  <ProjectSignal slug={item.href.split('/').pop() ?? 'mcp'} compact />
                )}
              </li>
            ))}
          </ul>
        )}

        {/* The raw optical front-end proof sits under selected work. */}
        {entry.data.section === 'selected-work' && (
          <ChannelToggle
            dataKey="optical-channels"
            caption="The strap's raw optical front-end — six channels at 25 Hz, decoded byte-by-byte from a 2,140-byte offload buffer. My own WHOOP MG. Toggle any channel."
          />
        )}

        <Body />
      </section>
    ))
  }
</Layout>

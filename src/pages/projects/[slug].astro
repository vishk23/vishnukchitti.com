---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import WaveformScrub from '../../components/WaveformScrub.astro';
import ChannelToggle from '../../components/ChannelToggle.astro';
import PpgBurst from '../../components/PpgBurst.astro';
import Hypnogram from '../../components/Hypnogram.astro';
import HrvSeries from '../../components/HrvSeries.astro';
import HrRecovery from '../../components/HrRecovery.astro';

interface Props {
  entry: CollectionEntry<'projects'>;
}

// One static page per project entry: /projects/noop, /arbiter, /rhapsode, /mcp.
export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);

// noop is the flagship deep-dive: it hosts the scroll-story that walks a strap's
// raw BLE bytes through to shipped physiology, beside the real captured figures.
const isNoop = entry.data.slug === 'noop';
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <p class="back-link"><a href="/#work">← Selected work</a></p>
  <article>
    <h1>{entry.data.title}</h1>
    <p class="proj-role">
      {entry.data.role}
      {entry.data.period && ` · ${entry.data.period}`}
    </p>
    <p class="proj-summary">{entry.data.summary}</p>

    <div class="proj-meta">
      {entry.data.stack && entry.data.stack.map((s) => <span>{s}</span>)}
      {
        entry.data.links &&
          entry.data.links.map((l) => <a href={l.href}>{l.label} ↗</a>)
      }
    </div>

    <Content />

    {
      isNoop && (
        <section
          class="scroll-story"
          aria-label="How the strap's raw bytes become physiology"
        >
          <div class="beat" data-beat="1">
            <p>
              <strong>Raw bytes.</strong> The WHOOP 5.0 streams undocumented
              Bluetooth Low Energy. What arrives is an opaque buffer of bytes —
              no schema, no field names, no help.
            </p>
          </div>

          <div class="beat" data-beat="2">
            <p>
              <strong>Finding the frame.</strong> Capture enough buffers and
              structure emerges: fixed offsets, repeating strides. The bytes
              resolve into signals the strap never meant to explain.
            </p>
          </div>

          <div class="beat" data-beat="3">
            <p>
              <strong>The optical signal.</strong> One buffer carries the raw
              v26 PPG — the green-light pulse of blood flow. The strap emits it
              as a per-second burst, and I persist it past a single reading.
            </p>
            <PpgBurst
              dataKey="ppg-hero"
              caption="A single decoded 24-sample v26 optical PPG burst (24 Hz, ~1 s), decoded from WHOOP 5.0 hardware captures — the strap emits per-second bursts, not a continuous stream."
            />
          </div>

          <div class="beat" data-beat="4">
            <p>
              <strong>The whole optical front-end.</strong> The persisted burst
              was one channel. The strap's raw optical offload banks{' '}
              <em>six</em> — two green photodiodes, red, infrared, and two dark
              references — twenty-five times a second. I decoded the 2,140-byte
              buffer to the byte: the green LED drive current, the per-photodiode
              offset DACs, every channel slot.
            </p>
            <ChannelToggle
              dataKey="optical-channels"
              caption="The raw optical front-end — six channels at 25 Hz, decoded from the WHOOP MG's 2,140-byte offload buffer. My own strap, 2026-07-14. Toggle any channel; wavelength labels are physics-inferred."
            />
          </div>

          <div class="beat" data-beat="5">
            <p>
              <strong>A pulse from raw light.</strong> The green channel, over
              time, is a clean cardiac pulse. Track it against the strap's own
              heart rate across a resting window and it lands within a beat:
              median error 1 bpm, every recovered reading within 6. Heart rate,
              rebuilt from the light the sensor never exposed.
            </p>
            <WaveformScrub
              mode="scrub"
              dataKey="ppg-continuous"
              caption="45 continuous seconds of the recovered green PPG (25 Hz). My own WHOOP MG, 2026-07-14. Scroll to scrub."
            />
            <HrRecovery
              dataKey="hr-recovery"
              caption="Recovered heart rate against the strap's own, across a 5-minute resting window. My own WHOOP MG, 2026-07-14."
            />
          </div>

          <div class="beat" data-beat="6">
            <p>
              <strong>Parsed motion.</strong> Another buffer resolves into six
              axes of motion — the strap's own record of how the wrist moved,
              decoded from bytes it never meant to explain.
            </p>
            <ChannelToggle
              dataKey="imu-segment"
              caption="One real second of 6-axis IMU (accelerometer + gyroscope, 100 Hz), decoded from WHOOP 5.0 hardware captures. Only one offload buffer exists — toggle any channel."
            />
          </div>

          <div class="beat" data-beat="7">
            <p>
              <strong>From signal to sleep.</strong> Old scoring saw elevated
              heart rate and called it WAKE — even on a dead-still wrist. That's
              a false wake.
            </p>
          </div>

          <div class="beat" data-beat="8">
            <p>
              <strong>Corroboration.</strong> Cross-reference the IMU: no
              motion, no wake. A racing heart on a motionless wrist stays asleep.
              The hypnogram gets honest.
            </p>
            <Hypnogram
              dataKey="hypnogram"
              caption="One night's sleep stages (awake / REM / light / deep) — my own WHOOP data, night of 2026-06-29→30."
            />
          </div>

          <div class="beat" data-beat="9">
            <p>
              <strong>Shipped upstream.</strong> All of it lands as merged pull
              requests in the base app — 13 of them — not a fork nobody runs.
              Real users, real straps, real derived signals like these:
            </p>
            <WaveformScrub
              mode="scrub"
              dataKey="hr-day"
              caption="A full day of my own heart rate — 1,441 real one-minute readings from 2026-06-30 (WHOOP). Scroll to scrub across the day."
            />
            <HrvSeries
              dataKey="hrv-series"
              caption="Nightly HRV (RMSSD) across 20 sleep sessions — my own WHOOP data, 2026-06-27 → 2026-07-14."
            />
          </div>
        </section>
      )
    }
  </article>
</Layout>

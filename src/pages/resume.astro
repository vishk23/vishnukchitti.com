---
import Layout from '../layouts/Layout.astro';

// Resume route. Links to the generated PDF résumé (asset dropped in by a later
// pass; the path is stable so the link resolves once the file lands).
const resumeHref = '/vishnu-kchittibhooma-resume.pdf';
---

<Layout
  title="Resume — Vishnu Kchittibhooma"
  description="Data engineer, Boston. Microsoft Fabric platform (343M+ rows), FDIC credit logic on a $2.64B portfolio, prior RAG work at Johnson & Johnson."
>
  <article>
    <h1>Resume</h1>
    <p>
      <a href={resumeHref}>Download résumé (PDF)</a>
    </p>
  </article>
</Layout>
